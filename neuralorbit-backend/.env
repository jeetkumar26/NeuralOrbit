# ============================================================
#  NeuralOrbit Backend — Environment Variables
#  Copy this to .env and fill in your real values
# ============================================================

# ── App ──────────────────────────────────────────────────────
APP_ENV=development

# Auth enforcement — set to false for local dev without JWT
AUTH_REQUIRED=false

# CORS origins (comma-separated)
APP_CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5500,http://localhost:8080

# ── Supabase ─────────────────────────────────────────────────
